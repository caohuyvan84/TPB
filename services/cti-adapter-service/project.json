{
  "name": "cti-adapter-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/cti-adapter-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/services/cti-adapter-service",
        "main": "services/cti-adapter-service/src/main.ts",
        "tsConfig": "services/cti-adapter-service/tsconfig.app.json",
        "webpackConfig": "services/cti-adapter-service/webpack.config.js"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "cti-adapter-service:build"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/services/cti-adapter-service"],
      "options": {
        "jestConfig": "services/cti-adapter-service/jest.config.ts",
        "passWithNoTests": false
      }
    }
  },
  "tags": ["type:service", "scope:cti"]
}
