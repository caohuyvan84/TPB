[Unit]
Description=TPB Layout Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3014"
ExecStart=/usr/bin/npx nx run layout-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/layout-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/layout-service.log

[Install]
WantedBy=multi-user.target
