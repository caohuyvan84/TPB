[Unit]
Description=TPB Ai Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3009"
ExecStart=/usr/bin/npx nx run ai-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/ai-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/ai-service.log

[Install]
WantedBy=multi-user.target
