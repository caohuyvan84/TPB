[Unit]
Description=TPB Workflow Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3015"
ExecStart=/usr/bin/npx nx run workflow-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/workflow-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/workflow-service.log

[Install]
WantedBy=multi-user.target
