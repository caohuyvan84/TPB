[Unit]
Description=TPB Audit Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3011"
ExecStart=/usr/bin/npx nx run audit-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/audit-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/audit-service.log

[Install]
WantedBy=multi-user.target
