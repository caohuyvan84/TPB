[Unit]
Description=TPB Media Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3010"
ExecStart=/usr/bin/npx nx run media-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/media-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/media-service.log

[Install]
WantedBy=multi-user.target
