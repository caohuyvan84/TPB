[Unit]
Description=TPB Report Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3018"
ExecStart=/usr/bin/npx nx run report-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/report-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/report-service.log

[Install]
WantedBy=multi-user.target
