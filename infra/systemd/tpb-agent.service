[Unit]
Description=TPB Agent Service
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/project/AgentdesktopTPB
Environment="NODE_ENV=production"
Environment="PORT=3002"
ExecStart=/usr/bin/npx nx run agent-service:serve
Restart=always
RestartSec=10
StandardOutput=append:/opt/project/AgentdesktopTPB/logs/agent-service.log
StandardError=append:/opt/project/AgentdesktopTPB/logs/agent-service.log

[Install]
WantedBy=multi-user.target
