# TPB CRM Platform - Environment Variables

# ======================
# Frontend Configuration
# ======================
VITE_API_BASE_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001/ws

# ======================
# Database Configuration
# ======================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# Database Names (19 databases)
DB_IDENTITY=identity_db
DB_AGENT=agent_db
DB_INTERACTION=interaction_db
DB_TICKET=ticket_db
DB_CUSTOMER=customer_db
DB_NOTIFICATION=notification_db
DB_KNOWLEDGE=knowledge_db
DB_BFSI=bfsi_db
DB_AI=ai_db
DB_MEDIA=media_db
DB_AUDIT=audit_db
DB_OBJECT_SCHEMA=object_schema_db
DB_LAYOUT=layout_db
DB_WORKFLOW=workflow_db
DB_ENRICHMENT=enrichment_db
DB_DASHBOARD=dashboard_db
DB_REPORT=report_db
DB_CTI=cti_db
DB_GATEWAY=gateway_db

# ======================
# Redis Configuration
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ======================
# Kafka Configuration
# ======================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=tpb-crm

# ======================
# Elasticsearch Configuration
# ======================
ELASTICSEARCH_NODE=http://localhost:9200

# ======================
# SeaweedFS Configuration
# ======================
SEAWEEDFS_ENDPOINT=http://localhost:8333
SEAWEEDFS_ACCESS_KEY=admin
SEAWEEDFS_SECRET_KEY=admin123

# ======================
# Temporal Configuration
# ======================
TEMPORAL_ADDRESS=localhost:7233

# ======================
# Authentication Configuration
# ======================
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ======================
# CORS Configuration
# ======================
CORS_ORIGIN=http://localhost:3000

# ======================
# Service Ports
# ======================
PORT_IDENTITY=3001
PORT_AGENT=3002
PORT_INTERACTION=3003
PORT_TICKET=3004
PORT_CUSTOMER=3005
PORT_NOTIFICATION=3006
PORT_KNOWLEDGE=3007
PORT_BFSI=3008
PORT_AI=3009
PORT_MEDIA=3010
PORT_AUDIT=3011
PORT_OBJECT_SCHEMA=3013
PORT_LAYOUT=3014
PORT_WORKFLOW=3015
PORT_ENRICHMENT=3016
PORT_DASHBOARD=3017
PORT_REPORT=3018
PORT_CTI=3019

# ======================
# Email Configuration (MailHog)
# ======================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ======================
# Superset Configuration
# ======================
SUPERSET_URL=http://localhost:8088
SUPERSET_USERNAME=admin
SUPERSET_PASSWORD=admin

# ======================
# Node Environment
# ======================
NODE_ENV=development
